# ============================================
# American Dream Mall RAG Chatbot - API Keys
# ============================================
# Copy this file, rename it to .env
# and fill in your actual API keys

# ------------------------------------------
# NOTE: This project is built using completely
# free and open-source models.
# We have used only these two API keys below.
# However, you can also swap these with paid
# models like:
# - Google Gemini (for embeddings or LLM)
# - Anthropic Claude (for LLM answering)
# - OpenAI GPT-4 (for embeddings or LLM)
# with slight changes in the code.
# ------------------------------------------

# ------------------------------------------
# HuggingFace API Key
# Used for: Embeddings (sentence-transformers)
# Get it from: huggingface.co/settings/tokens
# Required: YES
# Free: YES
# ------------------------------------------
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ------------------------------------------
# OpenRouter API Key
# Used for: LLM answering (Arcee-AI Trinity)
# Get it from: openrouter.ai/keys
# Required: YES
# Free: YES (free models available)
# ------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
